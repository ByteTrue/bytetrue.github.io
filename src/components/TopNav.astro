---
// TopNav.astro
// Pinned navigation bar, 64px tall, black canvas background with white uppercase text
interface Props {
  activePath?: string;
}

const { activePath = '' } = Astro.props;

const navItems = [
  { name: 'HOME', href: '/' },
  { name: 'BLOG', href: '/blog' },
];
---

<header class="sticky top-0 z-50 w-full bg-canvas border-b border-hairline">
  <div class="max-w-[1440px] mx-auto h-16 px-6 md:px-12 flex items-center justify-between">
    <!-- Logo / Brand -->
    <a href="/" class="flex items-center gap-3 group">
      <!-- M tricolor accent block -->
      <div class="flex h-4 w-3 overflow-hidden">
        <div class="h-full w-1 bg-m-blue-light"></div>
        <div class="h-full w-1 bg-m-blue-dark"></div>
        <div class="h-full w-1 bg-m-red"></div>
      </div>
      <span class="font-display text-sm md:text-base font-bold tracking-[1.5px] text-white">
        BYTE TRUE
      </span>
    </a>

    <!-- Desktop Navigation -->
    <nav class="flex items-center gap-8">
      {navItems.map((item) => {
        const isActive = activePath === item.href || (item.href !== '/' && activePath.startsWith(item.href));
        return (
          <a
            href={item.href}
            class={`font-display text-[14px] font-bold tracking-[0.5px] transition-colors duration-200 relative py-2 ${
              isActive 
                ? 'text-white' 
                : 'text-body-text hover:text-white'
            }`}
          >
            {item.name}
            {isActive && (
              <span class="absolute bottom-0 left-0 right-0 h-[2px] bg-white"></span>
            )}
          </a>
        );
      })}
      
      <!-- GitHub Icon Link -->
      <a 
        href="https://github.com/ByteTrue" 
        target="_blank" 
        rel="noopener noreferrer"
        class="text-body-text hover:text-white transition-colors py-2"
        aria-label="GitHub"
      >
        <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.441 1.087 3.035.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.579.688.481C19.137 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z" />
        </svg>
      </a>
    </nav>
  </div>
</header>
